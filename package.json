{
  "name": "discord-support-platform",
  "version": "1.0.0",
  "description": "Modularer Discord-Bot mit Willkommen, Tickets, Voice-Support und REST-API.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy:commands": "node scripts/deploy-commands.js",
    "db:migrate": "node scripts/migrate.js",
    "api:key": "node scripts/create-api-key.js",
    "lint": "eslint .",
    "test": "node --test",
    "validate": "npm run lint && npm test"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "better-sqlite3": "^12.10.1",
    "cors": "^2.8.6",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "knex": "^3.2.10",
    "mysql2": "^3.22.5",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.1.3"
  }
}
