# Discord
DISCORD_TOKEN=replace-me
DISCORD_CLIENT_ID=replace-me
# Optional: Guild-spezifische Registrierung fuer Entwicklung
DISCORD_GUILD_ID=
# Privilegierte Intents nur aktivieren, wenn sie auch im Developer Portal
# unter Bot > Privileged Gateway Intents freigeschaltet wurden.
DISCORD_GUILD_MEMBERS_INTENT=false
DISCORD_MESSAGE_CONTENT_INTENT=false
# Registriert Commands bei jedem Start. Fuer Produktion optional deaktivierbar.
DISCORD_AUTO_DEPLOY_COMMANDS=true

# Datenbank: sqlite oder mysql2
DB_CLIENT=sqlite
DB_FILENAME=./data/bot.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=discord_bot
DB_USER=discord_bot
DB_PASSWORD=

# REST-API
API_ENABLED=true
API_HOST=127.0.0.1
API_PORT=3000
# Optionaler zentraler Schluessel, DB-API-Keys sind fuer Produktion empfohlen.
API_MASTER_KEY=
API_CORS_ORIGINS=
API_RATE_LIMIT=120

# Betrieb
LOG_LEVEL=info
AUTO_MIGRATE=true
INSTANCE_ID=
INSTANCE_ROLE=primary
CONFIG_FILE=./config/defaults.json
